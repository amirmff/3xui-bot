# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3x-ui Panel URL (include port, no trailing slash)
PANEL_URL=https://your-server.com:2053

# 3x-ui Panel Credentials
PANEL_USERNAME=admin
PANEL_PASSWORD=admin

# Allowed Telegram User IDs (comma-separated)
# Find your ID with @userinfobot
ADMIN_CHAT_IDS=123456789

# Panel base path (leave empty if default)
PANEL_PATH=

# Proxy for connecting to panel (for when bot is on foreign server)
# Supports SOCKS5 and HTTP proxies
# Examples:
#   socks5://user:pass@ip:port
#   http://ip:port
#   socks5://127.0.0.1:1080
PROXY_URL=

# Cron / Scheduler Settings
# Traffic check interval in seconds (default: 300 = 5 minutes)
TRAFFIC_CHECK_INTERVAL=300

# Expiry check interval in seconds (default: 3600 = 1 hour)
EXPIRY_CHECK_INTERVAL=3600

# Auto restart Xray when clients exceed traffic limit (true/false)
ENABLE_AUTO_RESTART=true
